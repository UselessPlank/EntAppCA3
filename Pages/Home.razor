@page "/"

<div class="layout-container d-flex flex-column min-vh-100">
    <!-- Main Content -->
    <div class="container flex-grow-1 mt-3">
        <!-- Header Section -->
        <header class="text-center mb-3">
            <h1 class="display-6 text-primary">GameFindr - Video Game Database</h1>
            <p class="lead text-secondary">Discover, explore, and track your favorite video games effortlessly.</p>
        </header>

        <!-- Featured Image Section -->
<div class="image-container mb-4 text-center">
    <img src="/logo.png" alt="RAWG API" class="featured-image" />
</div>

        <!-- About Section -->
        <section class="info-section bg-light p-4 rounded-3 shadow-sm text-center">
            <h4 class="text-dark mb-3"><strong>What You Can Do</strong></h4>
            <p>
                GameFindr is a web application that leverages the RAWG API to provide you with detailed information about thousands of video games.
            </p>
            <p>
                You can search for your favorite games, discover detailed information about new titles, view ratings, and more.
            </p>
        </section>
    </div>

    <!-- Footer Section -->
    <footer class="footer text-center text-muted p-3">
        &copy; 2024 Jason O'Connor | Powered by RAWG API
    </footer>
</div>
